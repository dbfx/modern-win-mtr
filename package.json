{
  "name": "modern-win-mtr",
  "productName": "Modern MTR",
  "version": "1.1.0",
  "description": "A beautiful, modern MTR (My Traceroute) tool built with Electron, React, and TypeScript",
  "main": ".vite/build/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/dbfx/modern-win-mtr.git"
  },
  "author": "dbfx",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dbfx/modern-win-mtr/issues"
  },
  "homepage": "https://github.com/dbfx/modern-win-mtr#readme",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "generate-icons": "node scripts/generate-icon.mjs",
    "make": "npm run generate-icons && electron-forge make",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:first": "standard-version --first-release",
    "prepare": "husky"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-simple-maps": "^3.0.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-simple-maps": "^3.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "40.7.0",
    "husky": "^9.1.7",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "standard-version": "^9.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^5.4.21"
  }
}
